{
  "manifest_version": 3,
  "name": "ScoutLead Extractor",
  "version": "2.0.0",
  "description": "Enterprise-grade AI Lead Intelligence Platform (100% Local)",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
